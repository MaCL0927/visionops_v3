# Copied to /etc/visionops_v3/carton_palletizing.env
VISIONOPS_V3_ROOT=/opt/visionops_v3
VISIONOPS_CARTON_PALLETIZING_CONFIG=/etc/visionops_v3/carton_palletizing.yaml
# VISIONOPS_RUNTIME_BIN=/opt/visionops_v3/build-rknn/edge/runtime_cpp/visionops_runtime_mock
# VISIONOPS_CARTON_PALLETIZING_MODEL_DIR=/opt/visionops_v3/models/carton_palletizing/current
VISIONOPS_CAMERA_SELECTION_FILE=/opt/visionops_v3/config/active_camera.json
# Optional one-off override: VISIONOPS_CAMERA_BRIDGE_URL_OVERRIDE=http://127.0.0.1:18181

# Python environment containing PyYAML, numpy and OpenCV for RGB-D processing.
VISIONOPS_VENV=/opt/visionops_v3/venv
# Segmentation model for carton contour / grasp-point task.
# VISIONOPS_CARTON_BOX_GRASP_MODEL_DIR=/opt/visionops_v3/models/carton_box_grasp/current
# Runtime HTTP request workers. Inference remains serialized to one RKNN context,
# while status/snapshot requests can be handled concurrently.
VISIONOPS_RUNTIME_HTTP_WORKERS=4
VISIONOPS_RUNTIME_HTTP_QUEUE=64
