[Unit]
Description=VisionOps v3 Carton Box Grasp Segmentation RKNN Runtime
After=network-online.target visionops-orbbec336l-bridge.service
Wants=network-online.target visionops-orbbec336l-bridge.service

[Service]
Type=simple
WorkingDirectory=/opt/visionops_v3
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/etc/visionops_v3/carton_palletizing.env
ExecStart=/opt/visionops_v3/production/carton_palletizing/scripts/start_box_grasp_runtime.sh
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
