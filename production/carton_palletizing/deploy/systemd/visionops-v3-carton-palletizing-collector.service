[Unit]
Description=VisionOps v3 Carton Palletizing Collector Web
After=network-online.target visionops-v3-carton-palletizing-runtime.service visionops-v3-carton-palletizing-app.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/visionops_v3
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/etc/visionops_v3/carton_palletizing.env
ExecStart=/opt/visionops_v3/production/carton_palletizing/scripts/start_collector.sh
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
