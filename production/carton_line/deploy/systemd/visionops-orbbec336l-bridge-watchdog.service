[Unit]
Description=VisionOps Orbbec 336L Camera Recovery Watchdog
After=network-online.target visionops-orbbec336l-bridge.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/visionops_v3/carton_line.env
ExecStart=/opt/visionops_v3/production/carton_line/scripts/watch_orbbec336l_bridge.sh
TimeoutStartSec=45
