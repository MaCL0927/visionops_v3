[Unit]
Description=VisionOps HP60C Camera Recovery Watchdog
After=network-online.target visionops-hp60c-sdk-bridge.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/visionops_v3/carton_line.env
ExecStart=/opt/visionops_v3/production/carton_line/scripts/watch_hp60c_bridge.sh
TimeoutStartSec=60
