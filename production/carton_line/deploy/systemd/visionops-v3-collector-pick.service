[Unit]
Description=VisionOps v3 Carton Line - Tube Pick Web
After=network-online.target visionops-v3-runtime-pick.service visionops-v3-tcp-pick.service
Wants=network-online.target visionops-v3-runtime-pick.service visionops-v3-tcp-pick.service

[Service]
Type=simple
User=neardi
WorkingDirectory=/opt/visionops_v3
EnvironmentFile=-/etc/visionops_v3/carton_line.env
ExecStart=/opt/visionops_v3/production/carton_line/scripts/start_collector.sh pick
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
