# Copied by install_services.sh to /etc/visionops_v3/carton_line.env
VISIONOPS_V3_ROOT=/opt/visionops_v3
VISIONOPS_VENV=/opt/visionops_v3/venv
VISIONOPS_CARTON_LINE_CONFIG=/etc/visionops_v3/carton_line.yaml
VISIONOPS_CAMERA_SELECTION_FILE=/opt/visionops_v3/config/active_camera.json
VISIONOPS_PARTITION_MODEL_DIR=/opt/visionops_v3/models/carton_partition_check/current
VISIONOPS_TUBE_MODEL_DIR=/opt/visionops_v3/models/carton_tube_check/current
VISIONOPS_PICK_MODEL_DIR=/opt/visionops_v3/models/tube_pick_vision/current

# Tube-pick Runtime watchdog（仅 tube-pick profile 使用）
VISIONOPS_PICK_RUNTIME_URL=http://127.0.0.1:28083
VISIONOPS_PICK_RUNTIME_SERVICE=visionops-v3-runtime-pick.service
VISIONOPS_PICK_WATCHDOG_STALE_MS=5000
VISIONOPS_PICK_WATCHDOG_COOLDOWN_S=30
VISIONOPS_PICK_WATCHDOG_RECOVERY_WAIT_S=3

# Tube-pick external-box WebSocket service
VISIONOPS_PICK_WS_SERVICE=visionops-v3-ws-pick.service

# HP60C external watchdog
VISIONOPS_HP60C_BRIDGE_URL=http://127.0.0.1:18181
VISIONOPS_HP60C_BRIDGE_SERVICE=visionops-hp60c-sdk-bridge.service
VISIONOPS_HP60C_WATCHDOG_STALE_MS=5000
VISIONOPS_HP60C_WATCHDOG_COOLDOWN_S=60
VISIONOPS_HP60C_WATCHDOG_RECOVERY_WAIT_S=20
VISIONOPS_HP60C_WATCHDOG_MAX_SERVICE_RESTARTS=10
VISIONOPS_HP60C_WATCHDOG_REBOOT_ENABLED=true
