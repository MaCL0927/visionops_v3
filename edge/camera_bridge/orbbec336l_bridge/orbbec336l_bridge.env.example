# VisionOps Orbbec Gemini 336L SDK HTTP bridge configuration

# Orbbec SDK root. The installer will also try several common locations when this path does not exist.
VISIONOPS_ORBBEC336L_SDK_ROOT=/opt/OrbbecSDK_v2.8.6
VISIONOPS_ORBBEC336L_SDK_INCLUDE_DIR=/opt/OrbbecSDK_v2.8.6/include
VISIONOPS_ORBBEC336L_SDK_LIB_DIR=/opt/OrbbecSDK_v2.8.6/tools

# HTTP server used by VisionOps web/runtime.
# Keep this different from HP60C 18181 if both cameras may be used at the same time.
VISIONOPS_ORBBEC336L_HTTP_HOST=0.0.0.0
VISIONOPS_ORBBEC336L_HTTP_PORT=18182

# Stream settings. Use 0 width/height to let the SDK choose a default profile.
VISIONOPS_ORBBEC336L_COLOR_WIDTH=640
VISIONOPS_ORBBEC336L_COLOR_HEIGHT=480
VISIONOPS_ORBBEC336L_DEPTH_WIDTH=640
VISIONOPS_ORBBEC336L_DEPTH_HEIGHT=480
VISIONOPS_ORBBEC336L_FPS=30

VISIONOPS_ORBBEC336L_JPEG_QUALITY=100
VISIONOPS_ORBBEC336L_MJPEG_FPS=10

# Optional image transforms.
VISIONOPS_ORBBEC336L_FLIP_VERTICAL=false
VISIONOPS_ORBBEC336L_FLIP_HORIZONTAL=false

# Depth output is stored as 16-bit PNG in millimeters by default.
# If the SDK depth scale is unavailable, the raw uint16 value is used.
VISIONOPS_ORBBEC336L_DEPTH_UNIT=mm

# Device selection. Leave empty to use the first connected Gemini 336L.
VISIONOPS_ORBBEC336L_SERIAL=

# Runtime working directory. The SDK may create temporary Log/ files here instead of under the source tree.
VISIONOPS_ORBBEC336L_RUNTIME_DIR=/run/visionops-orbbec336l-bridge

# 7x24 camera freshness and automatic reconnect.
# RGB or D2C depth older than this threshold makes the bridge invalidate cached
# frames, close the MJPEG connection and rebuild the complete SDK Pipeline.
VISIONOPS_ORBBEC336L_STALE_TIMEOUT_MS=3000

# Maximum time allowed after opening a Pipeline before both first RGB and depth
# frames must arrive.
VISIONOPS_ORBBEC336L_FIRST_FRAME_TIMEOUT_MS=5000

# Reconnect exponential backoff: 1s, 2s, 4s ... up to 30s.
VISIONOPS_ORBBEC336L_RECONNECT_INITIAL_MS=1000
VISIONOPS_ORBBEC336L_RECONNECT_MAX_MS=30000

# Bridge /health raises alarm_active after the camera has remained unhealthy for
# this many seconds. Robot WebSocket status uses the same alarm state.
VISIONOPS_ORBBEC336L_RECONNECT_FAILURE_ALARM_SEC=15

# Raw RGB888 transport for the local C++ Runtime. The Bridge writes a double-buffered
# POSIX shared memory object; Runtime falls back to HTTP JPEG if configured to do so.
VISIONOPS_ORBBEC336L_SHARED_RGB_ENABLED=true
VISIONOPS_ORBBEC336L_SHARED_RGB_NAME=/visionops_orbbec336l_rgb

# D2C-aligned uint16 millimetre depth transport for local business applications.
VISIONOPS_ORBBEC336L_SHARED_DEPTH_ENABLED=true
VISIONOPS_ORBBEC336L_SHARED_DEPTH_NAME=/visionops_orbbec336l_depth
