# VisionOps v3 HP60C / HP60CN Angstrong SDK Bridge
# HP60C dedicated HTTP port: 18181; Orbbec 336L remains on 18182.
VISIONOPS_HP60C_SDK_ROOT=/home/neardi/AngstrongCameraSdk_v1.2.61.20250910/demo/linux_ros/linux
VISIONOPS_HP60C_SDK_LIB_DIR=/home/neardi/AngstrongCameraSdk_v1.2.61.20250910/demo/linux_ros/linux/libs/lib/aarch64-linux-gnu-gcc-5
VISIONOPS_HP60C_CONFIG=/home/neardi/AngstrongCameraSdk_v1.2.61.20250910/demo/linux_ros/linux/configurationfiles/hp60c_v2_01_20241104_configEncrypt.json

VISIONOPS_HP60C_HTTP_HOST=0.0.0.0
VISIONOPS_HP60C_HTTP_PORT=18181
VISIONOPS_HP60C_JPEG_QUALITY=85
VISIONOPS_HP60C_MJPEG_FPS=10

# The encrypted vendor config controls the actual sensor profile/exposure.
# These values describe/validate the profile exposed to VisionOps Web.
VISIONOPS_HP60C_COLOR_WIDTH=640
VISIONOPS_HP60C_COLOR_HEIGHT=480
VISIONOPS_HP60C_DEPTH_WIDTH=640
VISIONOPS_HP60C_DEPTH_HEIGHT=480
VISIONOPS_HP60C_FPS=30

VISIONOPS_HP60C_FLIP_VERTICAL=true
VISIONOPS_HP60C_FLIP_HORIZONTAL=false
# auto | mjpeg | rgb | yuyv
VISIONOPS_HP60C_RGB_SOURCE=auto
# bgr | rgb
VISIONOPS_HP60C_RGB_ORDER=bgr
VISIONOPS_HP60C_DEPTH_ALIGNED_TO_COLOR=true

# Stale-frame detection and internal SDK re-enumeration.
VISIONOPS_HP60C_STALE_TIMEOUT_MS=3000
VISIONOPS_HP60C_FIRST_FRAME_TIMEOUT_MS=8000
VISIONOPS_HP60C_RECONNECT_INITIAL_MS=1000
VISIONOPS_HP60C_RECONNECT_MAX_MS=30000
VISIONOPS_HP60C_RECONNECT_FAILURE_ALARM_SEC=15

# Optional pinhole intrinsics for /api/coordinate/deproject.
# Leave zero until calibrated/exported from the HP60C SDK tool.
VISIONOPS_HP60C_FX=0
VISIONOPS_HP60C_FY=0
VISIONOPS_HP60C_CX=0
VISIONOPS_HP60C_CY=0
