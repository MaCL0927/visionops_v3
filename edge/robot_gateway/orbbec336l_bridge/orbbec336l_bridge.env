# VisionOps Orbbec Gemini 336L SDK HTTP bridge configuration

# Orbbec SDK root. The installer will also try several common locations when this path does not exist.
VISIONOPS_ORBBEC336L_SDK_ROOT=/opt/OrbbecSDK_v2.8.6
VISIONOPS_ORBBEC336L_SDK_INCLUDE_DIR=/opt/OrbbecSDK_v2.8.6/include
VISIONOPS_ORBBEC336L_SDK_LIB_DIR=/opt/OrbbecSDK_v2.8.6/tools

# HTTP server used by VisionOps web/runtime.
# Keep this different from HP60C 18181 if both cameras may be used at the same time.
VISIONOPS_ORBBEC336L_HTTP_HOST=127.0.0.1
VISIONOPS_ORBBEC336L_HTTP_PORT=18182

# Stream settings. Use 0 width/height to let the SDK choose a default profile.
VISIONOPS_ORBBEC336L_COLOR_WIDTH=1280
VISIONOPS_ORBBEC336L_COLOR_HEIGHT=720
VISIONOPS_ORBBEC336L_DEPTH_WIDTH=1280
VISIONOPS_ORBBEC336L_DEPTH_HEIGHT=720
VISIONOPS_ORBBEC336L_FPS=30

VISIONOPS_ORBBEC336L_JPEG_QUALITY=100
VISIONOPS_ORBBEC336L_MJPEG_FPS=10

# Optional image transforms.
VISIONOPS_ORBBEC336L_FLIP_VERTICAL=false
VISIONOPS_ORBBEC336L_FLIP_HORIZONTAL=false

# Depth output is stored as 16-bit PNG in millimeters by default.
# If the SDK depth scale is unavailable, the raw uint16 value is used.
VISIONOPS_ORBBEC336L_DEPTH_UNIT=mm

# Device selection. Leave empty to use the first connected Gemini 336L.
VISIONOPS_ORBBEC336L_SERIAL=
