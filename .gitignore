# -----------------------------------------------------------------------------
# Local environment, secrets and device-private configuration
# -----------------------------------------------------------------------------
.env
.env.*
*.env
!*.env.example
!**/*.env.example
secrets/
*.pem
*.key
*.p12
*.crt

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# C / C++ build outputs
# -----------------------------------------------------------------------------
build/
build-*/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
*.o
*.obj
*.a
*.so
*.so.*
*.out
bin/

# -----------------------------------------------------------------------------
# Models, training outputs and generated packages
# -----------------------------------------------------------------------------
/models/**
!/models/README.md
*.pt
*.pth
*.onnx
*.rknn
*.engine
*.weights
runs/
mlruns/
artifacts/
checkpoints/
training/export/generated/
published_models/

# -----------------------------------------------------------------------------
# Runtime data, datasets and debug outputs
# -----------------------------------------------------------------------------
/server_data/**
!/server_data/.gitkeep
/var/
/data/
/datasets/
logs/
Log/
diagnostics/
**/latest/
**/debug_output/

# Generated runtime configuration
/configs/runtime/generated/
/configs/runtime/*.env
*.env.bak*
*.bak
*.tmp

# -----------------------------------------------------------------------------
# Media and large local artifacts
# -----------------------------------------------------------------------------
*.jpg
*.jpeg
*.png
*.bmp
*.webp
*.tif
*.tiff
*.mp4
*.avi
*.mkv
*.mov
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.xz
*.7z
*.log

# Keep versioned calibration assets even when their extensions are ignored.
!/production/**/assets/*.png
!/production/**/assets/*.jpg

# -----------------------------------------------------------------------------
# Editors and operating systems
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
